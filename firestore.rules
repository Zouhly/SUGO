// Firestore Security Rules – restrict access to your account only.
//
// Deploy with: firebase deploy --only firestore:rules
//
// Replace YOUR_USER_ID with your Firebase Auth UID.

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Only the owner (your UID) can read/write anything.
    function isOwner() {
      return request.auth != null && request.auth.uid == 'YOUR_USER_ID';
    }

    // Products collection
    match /products/{productId} {
      allow read, write: if isOwner();
    }

    // Scan logs collection
    match /scanLogs/{logId} {
      allow read, write: if isOwner();
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
